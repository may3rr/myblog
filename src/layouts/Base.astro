---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <ClientRouter />

    <script is:inline>
        (function () {
            const set = () => document.documentElement.style.setProperty('--vw', document.documentElement.clientWidth + 'px');
            set();
            window.addEventListener('resize', set);
        })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Lora:ital,wght@0,400;0,500;1,400&family=Noto+Serif+SC:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
    <div class="container">
        <slot />
    </div>
</body>
</html>

<style is:global>
    @import '../styles/global.css';
</style>
